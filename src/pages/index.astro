---
import Layout from '../layouts/Layout.astro';
import Subdomains from '../components/Subdomains.svelte';
---

<Layout>
    <main class="mt-40 mb-12 lg:mt-12 max-w-[min(90vw,750px)] lg:max-w-210">
        <ul
            class="hidden lg:flex justify-start items-end gap-0.75 m-0 p-0 text-sm h-12"
        >
            <Subdomains client:load />
        </ul>
        <div class="p-3 bg-white rounded-xl lg:rounded-tl-none shadow-lg">
            <div class="flex flex-col lg:flex-row px-3">
                <div
                    class="flex-none mx-auto -mt-12 mb-3 lg:mt-0 lg:my-0 px-3 lg:py-3"
                >
                    <div class="avatar">
                        <div class="w-44 border-white border-4 rounded-full">
                            <img src="/og.png" alt="Faizal Chan." />
                        </div>
                    </div>
                </div>
                <div class="flex flex-col gap-3 px-3 lg:px-3 lg:grow">
                    <div class="flex flex-col gap-1 text-center lg:text-left">
                        <h1 class="lg:mt-3 text-3xl">
                            Faizal
                            <abbr class="cursor-help" title="Chaniago">
                                Chan.
                            </abbr>
                        </h1>
                        <p class="text-gray-400">@moefc32</p>
                    </div>
                    <hr
                        class="lg:hidden mx-auto mt-1 mb-3 bg-gray-300 w-12 h-1 border-0"
                    />
                    <p>
                        Hi! I solve human problems by identifying root causes
                        and shaping them into practical, well-structured
                        solutions.
                    </p>
                    <p>
                        My work spans research, design, and code to ensure
                        decisions are grounded, solutions are usable, and
                        implementations remain efficient, each representing a
                        different layer of how I approach problem-solving.
                    </p>
                    <p class="mb-3 lg:mb-9">
                        Want to collaborate? Feel free to <a
                            href="mailto:hai@mf-chan.com"
                            class="text-blue-500 hover:text-green-500 underline"
                            >contact me</a
                        >!
                    </p>
                </div>
                <div class="flex flex-col gap-1 lg:hidden my-6 px-3">
                    <Subdomains client:load list={true} />
                </div>
            </div>
            <footer class="mb-3 text-gray-500 text-center lg:text-sm">
                Mfc &copy;
                <span data-footer-year></span>
            </footer>
        </div>
    </main>
</Layout>

<script is:inline>
    const getYear = new Date().getFullYear();
    const currentYear = (getYear > 2018 ? `2018 - ` : '') + getYear;

    const footerYear = document.querySelector('[data-footer-year]');
    if (footerYear) footerYear.textContent = currentYear;
</script>
